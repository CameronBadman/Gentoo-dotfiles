{
    "layer": "top",
    "position": "top",
    "height": 22,
    "spacing": 2,
    "margin-top": 2,
    "margin-left": 6,
    "margin-right": 6,
    
    "modules-left": [
        "custom/screenshot",
        "custom/recorder",
        "hyprland/workspaces",
        "clock"
    ],
    
    "modules-center": [
        "wireplumber"
    ],
    
    "modules-right": [
        "hyprland/window",
        "bluetooth",
        "network",
        "cpu",
        "temperature",
        "battery",
        "memory",
        "pulseaudio",
        "tray"
    ],

    "hyprland/workspaces": {
        "format": "{icon}",
        "format-icons": {
            "1": "َ°² ",
            "2": "َ°²¢",
            "3": "َ°²¤",
            "4": "َ°²¦",
            "5": "َ°²¨",
            "6": "َ°²ھ",
            "7": "َ°²¬",
            "8": "َ°²®",
            "9": "َ°²°",
            "10": "َ°؟¬"
        },
        "persistent-workspaces": {
            "*": 5
        },
        "on-click": "activate"
    },

    "clock": {
        "format": "َ°¥” {:%a %b %d  %I:%M %p}",
        "tooltip-format": "<tt><small>{calendar}</small></tt>",
        "calendar": {
            "mode": "month",
            "mode-mon-col": 3,
            "weeks-pos": "right",
            "on-scroll": 1,
            "on-click-right": "mode",
            "format": {
                "months": "<span color='#7e9cd8'><b>{}</b></span>",
                "days": "<span color='#dcd7ba'><b>{}</b></span>",
                "weeks": "<span color='#7fb4ca'><b>W{}</b></span>",
                "weekdays": "<span color='#c0a36e'><b>{}</b></span>",
                "today": "<span color='#ff5d62'><b><u>{}</u></b></span>"
            }
        }
    },

    "wireplumber": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°–پ muted",
        "format-icons": ["َ°•؟", "َ°–€", "َ°•¾"],
        "on-click": "wpctl set-mute @DEFAULT_AUDIO_SINK@ toggle",
        "scroll-step": 5.0
    },

    "hyprland/window": {
        "format": "{}",
        "max-length": 40,
        "separate-outputs": true
    },

    "bluetooth": {
        "format": "َ°‚¯ {status}",
        "format-connected": "َ°‚± {device_alias}",
        "format-connected-battery": "َ°‚± {device_alias} {device_battery_percentage}%",
        "tooltip-format": "{controller_alias}\t{controller_address}\n\n{num_connections} connected",
        "tooltip-format-connected": "{controller_alias}\t{controller_address}\n\n{num_connections} connected\n\n{device_enumerate}",
        "tooltip-format-enumerate-connected": "{device_alias}\t{device_address}",
        "tooltip-format-enumerate-connected-battery": "{device_alias}\t{device_address}\t{device_battery_percentage}%",
        "on-click": "blueman-manager"
    },

    "network": {
        "format-wifi": "َ°–© {essid}",
        "format-ethernet": "َ°ˆ€ {ipaddr}",
        "format-disconnected": "َ°–ھ disconnected",
        "tooltip-format": "{ifname}: {ipaddr}/{cidr}",
        "tooltip-format-wifi": "{essid} ({signalStrength}%)\n{ipaddr}/{cidr}",
        "on-click": "nm-connection-editor"
    },

    "cpu": {
        "format": "َ°»  {usage}%",
        "interval": 2,
        "tooltip": true
    },

    "temperature": {
        "hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
        "critical-threshold": 80,
        "format": "{icon} {temperatureC}آ°C",
        "format-icons": ["َ±ƒƒ", "َ°”ڈ", "َ±ƒ‚", "َ°¸پ", "َ°¸پ"],
        "interval": 2
    },

    "battery": {
        "bat": "BAT0",
        "interval": 10,
        "format": "{icon} {capacity}%",
        "format-charging": "َ°‚„ {capacity}%",
        "format-plugged": "َ°ڑ¥ {capacity}%",
        "format-icons": ["َ°پ؛", "َ°پ»", "َ°پ¼", "َ°پ½", "َ°پ¾", "َ°پ؟", "َ°‚€", "َ°‚پ", "َ°‚‚", "َ°پ¹"],
        "states": {
            "warning": 30,
            "critical": 15
        },
        "tooltip-format": "{time} remaining",
        "on-click": "~/.config/waybar/battery-info.sh"
    },

    "memory": {
        "format": "َ°چ› {}%",
        "interval": 2,
        "tooltip-format": "RAM: {used:0.1f}G / {total:0.1f}G\nSwap: {swapUsed:0.1f}G / {swapTotal:0.1f}G"
    },

    "pulseaudio": {
        "format": "{icon} {volume}%",
        "format-muted": "َ°–پ muted",
        "format-icons": {
            "headphone": "َ°‹‹",
            "hands-free": "َ°‹ژ",
            "headset": "َ°‹ژ",
            "phone": "َ°„œ",
            "portable": "َ°„œ",
            "car": "َ°„‹",
            "default": ["َ°•؟", "َ°–€", "َ°•¾"]
        },
        "on-click": "pavucontrol",
        "scroll-step": 5.0
    },

    "custom/screenshot": {
        "format": "{}",
        "interval": 3600,
        "exec": "~/.config/waybar/screenshot.sh status",
        "return-type": "json",
        "on-click": "~/.config/waybar/screenshot.sh capture"
    },

    "custom/recorder": {
        "format": "{}",
        "interval": 1,
        "exec": "~/.config/waybar/recorder.sh status",
        "return-type": "json",
        "on-click": "~/.config/waybar/recorder.sh toggle"
    },

    "tray": {
        "icon-size": 14,
        "spacing": 4
    }
}
